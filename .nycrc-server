{
  "all": true,
  "include": ["modules/*/server/**/*.js"],
  "exclude": [
    "modules/*/tests/**",
    "modules/*/server/**/*.model.js",
    "modules/*/server/models/**"
  ],
  "report-dir": "coverage/server",
  "temp-dir": ".nyc_output/server",
  "reporter": ["text-summary", "html", "json-summary", "lcov"],
  "cache": false
}
