{
  "all": true,
  "include": ["modules/*/server/**/*.js"],
  "exclude": [
    "modules/*/tests/**",
    "deploy/docker/data/**",
    "modules/*/server/**/*.model.js",
    "modules/*/server/models/**",
    "modules/core/server/jobs/send-push-message.server.job.js",
    "modules/users/server/jobs/user-welcome-sequence-first.server.job.js",
    "modules/users/server/jobs/user-welcome-sequence-second.server.job.js",
    "modules/users/server/jobs/user-welcome-sequence-third.server.job.js"
  ],
  "report-dir": "coverage/server",
  "temp-dir": ".nyc_output/server",
  "reporter": ["text-summary", "html", "json-summary", "lcov"],
  "cache": true
}
